diff --git a/cmake/build_wrapper.sh b/cmake/build_wrapper.sh
index 32bdf1c8..39f15e95 100755
--- a/cmake/build_wrapper.sh
+++ b/cmake/build_wrapper.sh
@@ -2,38 +2,58 @@
 # This is used for renaming symbols for the fat runtime, don't call directly
 # TODO: make this a lot less fragile!
 cleanup () {
-    rm -f ${SYMSFILE} ${KEEPSYMS}
+    rm -f ${SYMSFILE} ${KEEPSYMS} ${LIBC_SYMS}
 }
 
 NM="${NM:-nm}"
 OBJCOPY="${OBJCOPY:-objcopy}"
+OBJDUMP="${OBJDUMP:-objdump}"
 
 PREFIX=$1
 KEEPSYMS_IN=$2
 shift 2
 # $@ contains the actual build command
-OUT=$(echo "$@" | rev | cut -d ' ' -f 2- | rev | sed 's/.* -o \(.*\.o\).*/\1/')
+OUT=$(echo "$@" | rev | cut -d ' ' -f 2- | rev | sed 's/.* -o \([^ ]*\).*/\1/')
 trap cleanup INT QUIT EXIT
 SYMSFILE=$(mktemp -p /tmp ${PREFIX}_rename.syms.XXXXX)
 KEEPSYMS=$(mktemp -p /tmp keep.syms.XXXXX)
-# find the libc used by gcc
-LIBC_SO=$("$@" --print-file-name=libc.so.6)
+LIBC_SYMS=$(mktemp -p /tmp keep_libc.syms.XXXXX)
+# VECTORSCAN_LIBC_SO is set by build.rs to the correct C runtime path for the target:
+#   Linux:  libc.so.6    (via cc --print-file-name=libc.so.6)
+#   MinGW:  libmsvcrt.a  (via gcc --print-file-name=libmsvcrt.a)
+LIBC_SO="${VECTORSCAN_LIBC_SO:?VECTORSCAN_LIBC_SO must be set to the C runtime library path}"
 NM_FLAG="-f"
-if [ `uname` = "FreeBSD" ]; then
-    # for freebsd, we will specify the name, 
-    # we will leave it work as is in linux
-    LIBC_SO=/lib/libc.so.7
-    # also, in BSD, the nm flag -F corresponds to the -f flag in linux.
-    NM_FLAG="-F"
-fi
+# Shared libraries (.so) need nm -D for dynamic symbols; static archives (.a) do not
+NM_DYN=""
+case "${LIBC_SO}" in
+    *.so|*.so.*) NM_DYN="-D" ;;
+esac
 cp ${KEEPSYMS_IN} ${KEEPSYMS}
-# get all symbols from libc and turn them into patterns
-${NM} ${NM_FLAG} posix -g -D ${LIBC_SO} | sed 's/\([^ @]*\).*/^\1$/' >> ${KEEPSYMS}
+# Extract C runtime symbols as plain names for fixed-string matching.
+# awk -F'[ @]' strips @VERSION suffixes (Linux glibc); harmless on MinGW.
+# grep -F -x avoids regex metacharacter issues (e.g. brackets in libmsvcrt.a).
+${NM} ${NM_FLAG} posix -g ${NM_DYN} ${LIBC_SO} | awk -F'[ @]' '{print $1}' >> ${LIBC_SYMS}
 # build the object
 "$@"
 # rename the symbols in the object
-${NM} ${NM_FLAG} posix -g ${OUT} | cut -f1 -d' ' | grep -v -f ${KEEPSYMS} | sed -e "s/\(.*\)/\1\ ${PREFIX}_\1/" >> ${SYMSFILE}
+${NM} ${NM_FLAG} posix -g ${OUT} | cut -f1 -d' ' | grep -v -f ${KEEPSYMS} | \
+    grep -F -x -v -f ${LIBC_SYMS} | \
+    sed "s/\(.*\)/\1 ${PREFIX}_\1/" >> ${SYMSFILE}
 if test -s ${SYMSFILE}
 then
     ${OBJCOPY} --redefine-syms=${SYMSFILE} ${OUT}
 fi
+
+# Rename .refptr sections to avoid COMDAT conflicts (MinGW obj files only; no-op on Linux)
+SECTFILE=$(mktemp -p /tmp ${PREFIX}_sections.XXXXX)
+${OBJDUMP} -h ${OUT} 2>/dev/null | grep '\.rdata\$\.refptr\.' | awk '{print $2}' | while IFS= read -r sect; do
+    case "$sect" in
+        *.refptr.hs_*) continue ;;
+    esac
+    echo "--rename-section=${sect}=${PREFIX}_${sect}" >> ${SECTFILE}
+done 2>/dev/null
+
+if [ -s "${SECTFILE}" ]; then
+    ${OBJCOPY} $(cat ${SECTFILE}) ${OUT} 2>/dev/null
+fi
+rm -f "${SECTFILE}" 2>/dev/null
